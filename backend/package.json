{
  "name": "fightea-backend",
  "version": "1.0.0",
  "description": "FighTea Milk Tea Shop — REST API Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "hash": "node -e \"require('bcrypt').hash(process.argv[1],12).then(h=>{console.log('\\nHash:',h,'\\n')}).catch(console.error)\"",
    "health": "curl -s http://localhost:4000/api/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d)))\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
